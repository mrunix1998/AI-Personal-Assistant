APP_NAME="AI Personal Assistant"
ENVIRONMENT="local"
API_V1_PREFIX="/api/v1"
DATABASE_URL="postgresql+psycopg://postgres:postgres@db:5432/assistant_db"
REDIS_URL="redis://redis:6379/0"
SECRET_KEY="change-me"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY="paste-generated-fernet-key-here"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/integrations/google/callback"

# n8n integration
N8N_BASE_URL=http://n8n:5678
N8N_DAILY_SUMMARY_WEBHOOK_PATH=/webhook/daily-summary
N8N_AI_PLANNING_WEBHOOK_PATH=/webhook/ai-planning
N8N_WEBHOOK_SECRET=local-dev-secret

# Step 13: Telegram notifications via n8n
N8N_TELEGRAM_AGENDA_WEBHOOK_PATH=/webhook/telegram-daily-agenda

FERNET_KEY=ozcc+VnuXreLTWeVEeOyYsMggM0jnZZs4jIcfQOjX/A=
RUN_MIGRATIONS="true"

# Celery uses Redis by default via REDIS_URL.
